{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "MongoDb": {
    "ConnectionString": "mongodb://localhost:27017",
    "DatabaseName": "inventory_hold"
  },
  "RabbitMq": {
    "Host": "localhost",
    "Port": 5672,
    "Username": "guest",
    "Password": "guest",
    "VirtualHost": "/",
    "MaxRetries": 3,
    "InitialRetryDelayMs": 500
  },
  "Outbox": {
    "BatchSize": 50,
    "PollingIntervalSeconds": 5,
    "MaxRetries": 5
  },
  "HoldExpiry": {
    "PollingIntervalSeconds": 30,
    "MaxHoldDurationSeconds": 3600,
    "DefaultHoldDurationSeconds": 900
  }
}
